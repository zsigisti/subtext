# ─────────────────────────────────────────────────────────────
# Subtext environment configuration
# Copy to apps/server/.env (and apps/web/.env for the web origin)
# ─────────────────────────────────────────────────────────────

# --- Database ---------------------------------------------------
# Default: SQLite, zero external setup — perfect for local demos.
#   DATABASE_URL="file:./dev.db"
# To switch to PostgreSQL (production): set the provider in
# apps/server/prisma/schema.prisma to "postgresql" and point this at it:
#   DATABASE_URL="postgresql://user:password@localhost:5432/subtext?schema=public"
DATABASE_URL="file:./dev.db"

# --- Gemini AI --------------------------------------------------
# Get a free key at https://aistudio.google.com/apikey
# Server-side ONLY. Never expose this to the client.
GEMINI_API_KEY=""

# Model. Free tier (mid-2026) covers Flash / Flash-Lite only.
#   gemini-2.5-flash       ~10 RPM / 250 req-per-day
#   gemini-2.5-flash-lite  ~15 RPM / ~1000 req-per-day (use during heavy dev)
# Verify current model names + limits live in Google AI Studio.
GEMINI_MODEL="gemini-2.5-flash"

# Set to 1 to return canned structured responses WITHOUT calling Gemini.
# Lets you build/demo the UI offline and never burn quota. 0 = live calls.
GEMINI_MOCK="1"

# --- Auth / sessions --------------------------------------------
# Used to sign session cookies. Generate: openssl rand -hex 32
SESSION_SECRET="change-me-to-a-long-random-string"

# --- CORS / server ----------------------------------------------
# Origin the web app is served from (for cookie CORS).
WEB_ORIGIN="http://localhost:5173"
PORT="3000"

# --- Web (apps/web/.env) ----------------------------------------
# URL the browser uses to reach the tRPC server.
VITE_API_URL="http://localhost:3000"
