# Copy to .env for `docker compose up`. All have working defaults.

# --- Postgres ---
POSTGRES_USER=subtext
POSTGRES_PASSWORD=subtext
POSTGRES_DB=subtext

# --- App ---
# Leave GEMINI_MOCK=1 to run offline. For live AI: set a key and GEMINI_MOCK=0.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MOCK=1

# Generate: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# Where the browser reaches the app (used for CORS).
WEB_ORIGIN=http://localhost:8080
WEB_PORT=8080

# Seed the demo account on first start.
SEED_ON_START=true
